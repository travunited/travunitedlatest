generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Application {
  id                                   String                 @id
  userId                               String
  visaTypeId                           String
  country                              String?
  visaType                             String?
  status                               String                 @default("DRAFT")
  totalAmount                          Int                    @default(0)
  currency                             String                 @default("INR")
  processedById                        String?
  visaDocumentUrl                      String?
  PromoCodeUsage                       PromoCodeUsage[]
  notes                                String?
  createdAt                            DateTime               @default(now())
  updatedAt                            DateTime
  visaId                               String?
  feedbackEmailSentAt                  DateTime?
  visaSubTypeId                        String?
  invoiceUrl                           String?
  invoiceUploadedAt                    DateTime?
  invoiceUploadedByAdminId             String?
  User_Application_processedByIdToUser User?                  @relation("Application_processedByIdToUser", fields: [processedById], references: [id])
  User_Application_userIdToUser        User                   @relation("Application_userIdToUser", fields: [userId], references: [id])
  Visa                                 Visa?                  @relation(fields: [visaId], references: [id])
  VisaSubType                          VisaSubType?           @relation(fields: [visaSubTypeId], references: [id])
  documents                            Document[]
  ApplicationTraveller                 ApplicationTraveller[]
  Payment                              Payment[]
  Review                               Review[]
}

model Document {
  id                      String                   @id
  applicationId           String
  travellerId             String?
  filePath                String
  documentType            String?
  status                  String                   @default("PENDING")
  rejectionReason         String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime
  requirementId           String?
  fileSize                Int?
  Application             Application              @relation(fields: [applicationId], references: [id])
  VisaDocumentRequirement VisaDocumentRequirement? @relation(fields: [requirementId], references: [id])
  Traveller               Traveller?               @relation(fields: [travellerId], references: [id])

  @@map("ApplicationDocument")
}

model ApplicationTraveller {
  id            String      @id
  applicationId String
  travellerId   String
  createdAt     DateTime    @default(now())
  Application   Application @relation(fields: [applicationId], references: [id])
  Traveller     Traveller   @relation(fields: [travellerId], references: [id])
}

model AuditLog {
  id          String          @id
  timestamp   DateTime        @default(now())
  adminId     String?
  entityType  AuditEntityType
  entityId    String?
  action      AuditAction
  description String
  metadata    Json?
  User        User?           @relation(fields: [adminId], references: [id])
}

model BlogPost {
  id              String    @id
  title           String
  slug            String    @unique
  excerpt         String?
  coverImage      String?
  content         String
  category        String?
  readTime        String?
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
  metaTitle       String?
  metaDescription String?
  focusKeyword    String?
  author          String?
  isFeatured      Boolean   @default(false)
}

model Booking {
  id                               String             @id
  userId                           String
  tourId                           String?
  tourName                         String?
  status                           String             @default("DRAFT")
  totalAmount                      Int
  currency                         String             @default("INR")
  travelDate                       DateTime?
  processedById                    String?
  voucherUrl                       String?
  notes                            String?
  createdAt                        DateTime           @default(now())
  updatedAt                        DateTime
  foodPreference                   String?
  foodPreferenceNotes              String?
  languagePreference               String?
  languagePreferenceOther          String?
  driverPreference                 String?
  specialRequests                  String?
  policyAccepted                   Boolean            @default(false)
  policyAcceptedAt                 DateTime?
  policyAcceptedByUserId           String?
  cancellationReason               String?
  PromoCodeUsage                   PromoCodeUsage[]
  policyVersion                    String?
  policyAcceptedIp                 String?
  policyAcceptedUserAgent          String?
  documents                        Json?
  source                           String?            @default("WEBSITE")
  invoiceUrl                       String?
  invoiceUploadedAt                DateTime?
  invoiceUploadedByAdminId         String?
  User_Booking_processedByIdToUser User?              @relation("Booking_processedByIdToUser", fields: [processedById], references: [id])
  Tour                             Tour?              @relation(fields: [tourId], references: [id])
  User_Booking_userIdToUser        User               @relation("Booking_userIdToUser", fields: [userId], references: [id])
  BookingAddOn                     BookingAddOn[]
  BookingDocument                  BookingDocument[]
  BookingTraveller                 BookingTraveller[]
  Payment                          Payment[]
  Review                           Review[]
}

model BookingAddOn {
  id          String     @id
  bookingId   String
  addOnId     String?
  name        String
  pricingType String
  quantity    Int        @default(1)
  unitPrice   Int        @default(0)
  totalPrice  Int        @default(0)
  metadata    Json?
  createdAt   DateTime   @default(now())
  TourAddOn   TourAddOn? @relation(fields: [addOnId], references: [id])
  Booking     Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([addOnId])
  @@index([bookingId])
}

model BookingDocument {
  id               String            @id
  bookingId        String
  travellerId      String?
  type             String
  key              String
  fileName         String?
  status           String            @default("PENDING")
  rejectionReason  String?
  uploadedAt       DateTime          @default(now())
  updatedAt        DateTime
  fileSize         Int?
  Booking          Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  BookingTraveller BookingTraveller? @relation(fields: [travellerId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status])
  @@index([travellerId])
}

model BookingTraveller {
  id                     String            @id
  bookingId              String
  travellerId            String?
  createdAt              DateTime          @default(now())
  firstName              String            @default("")
  lastName               String            @default("")
  dateOfBirth            DateTime?
  age                    Int?
  gender                 String?
  nationality            String?
  passportNumber         String?
  passportExpiry         DateTime?
  passportIssuingCountry String?
  passportFileKey        String?
  isPassportRequired     Boolean           @default(false)
  updatedAt              DateTime          @default(now())
  fullName               String?
  travellerType          String?
  panNumber              String?
  aadharFileKey          String?
  BookingDocument        BookingDocument[]
  Booking                Booking           @relation(fields: [bookingId], references: [id])
  Traveller              Traveller?        @relation(fields: [travellerId], references: [id], onDelete: Restrict)
}

model CareerApplication {
  id             String                  @id
  name           String
  email          String
  phone          String
  location       String?
  positionTitle  String
  experience     Int?
  currentCompany String?
  expectedCtc    String?
  coverNote      String?
  resumeUrl      String
  status         CareerApplicationStatus @default(NEW)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime
  internalNotes  String?

  @@index([createdAt])
  @@index([email])
  @@index([positionTitle])
  @@index([status])
}

model ContactMessage {
  id        String   @id
  name      String?
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
}

model CorporateLead {
  id            String              @id
  companyName   String
  contactName   String
  email         String
  phone         String?
  message       String?
  status        CorporateLeadStatus @default(NEW)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime
  internalNotes String?
}

model Country {
  id        String   @id
  name      String
  code      String   @unique
  region    String?
  flagUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
  Tour      Tour[]
  Visa      Visa[]
}

model CustomTourRequest {
  id             String                  @id
  name           String
  email          String
  phone          String
  preferredDates String?
  pax            Int?
  budget         Int?
  message        String?
  attachments    Json?
  status         CustomTourRequestStatus @default(NEW)
  internalNotes  String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime

  @@index([createdAt])
  @@index([email])
  @@index([status])
}

model Notification {
  id           String    @id
  userId       String
  roleScope    String?
  type         String
  title        String
  message      String
  data         Json?
  link         String?
  channelEmail Boolean   @default(false)
  channelInApp Boolean   @default(true)
  channelPush  Boolean   @default(false)
  readAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([userId])
  @@index([userId, readAt])
}

model PasswordReset {
  id           String    @id
  userId       String
  tokenHash    String
  expiresAt    DateTime
  used         Boolean   @default(false)
  ip           String?
  userAgent    String?
  createdAt    DateTime  @default(now())
  otp          String?
  otpExpiresAt DateTime?
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([otpExpiresAt])
  @@index([otp])
  @@index([used])
  @@index([userId])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Payment {
  id                String       @id
  userId            String
  applicationId     String?
  bookingId         String?
  amount            Int
  currency          String       @default("INR")
  status            String
  razorpayOrderId   String?
  razorpayPaymentId String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime
  provider          String?
  method            String?
  promoCodeId       String?
  discountAmount    Int?
  metadata          Json?
  Application       Application? @relation(fields: [applicationId], references: [id])
  Booking           Booking?     @relation(fields: [bookingId], references: [id])
  User              User         @relation(fields: [userId], references: [id])
  PromoCode         PromoCode?   @relation(fields: [promoCodeId], references: [id])
}

model Review {
  id            String       @id
  type          ReviewType
  rating        Int
  title         String?
  comment       String
  isVisible     Boolean      @default(true)
  notes         String?
  userId        String?
  applicationId String?
  bookingId     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime
  reviewerName  String?
  imageKey      String?
  imageUrl      String?
  isFeatured    Boolean      @default(false)
  link          String?
  Application   Application? @relation(fields: [applicationId], references: [id])
  Booking       Booking?     @relation(fields: [bookingId], references: [id])
  User          User?        @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([isFeatured])
  @@index([isFeatured, isVisible])
}

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime
}

model SitePolicy {
  id        String   @id
  key       String   @unique
  title     String
  content   String
  version   String
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([key])
}

model TeamMember {
  id          String   @id
  name        String
  title       String?
  slug        String?  @unique
  bio         String?
  email       String?  @unique
  phone       String?
  photoKey    String?
  photoUrl    String?
  resumeKey   String?
  resumeUrl   String?
  socialLinks Json?
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([isActive, isFeatured])
  @@index([sortOrder])
}

model Tour {
  id                   String      @id
  name                 String
  destination          String
  duration             String
  price                Int
  description          String?
  itinerary            String?
  inclusions           String?
  exclusions           String?
  imageUrl             String?
  isActive             Boolean     @default(true)
  advancePercentage    Int?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime
  allowAdvance         Boolean     @default(false)
  basePriceInInr       Int?
  countryId            String?
  galleryImageUrls     String?
  heroImageUrl         String?
  importantNotes       String?
  isFeatured           Boolean     @default(false)
  metaDescription      String?
  metaTitle            String?
  overview             String?
  slug                 String?     @unique
  subtitle             String?
  availableDates       String?
  bestFor              String?
  bookingDeadline      DateTime?
  bookingPolicies      String?
  cancellationTerms    String?
  canonicalUrl         String?
  categoryId           String?
  citiesCovered        String?
  currency             String?     @default("INR")
  customizationOptions String?
  destinationCountry   String?
  destinationState     String?
  difficultyLevel      String?
  durationDays         Int?
  durationNights       Int?
  featuredImage        String?
  groupSizeMax         Int?
  groupSizeMin         Int?
  highlights           String?
  hotelCategories      String?
  images               String?
  maximumTravelers     Int?
  metaKeywords         String?
  minimumTravelers     Int?
  ogDescription        String?
  ogImage              String?
  ogTitle              String?
  originalPrice        Int?
  packageType          String?
  primaryDestination   String?
  region               String?
  regionTags           String?
  seasonalPricing      String?
  shortDescription     String?
  status               String?     @default("active")
  themes               String?
  tourSubType          String?
  tourType             String?
  twitterDescription   String?
  twitterImage         String?
  twitterTitle         String?
  requiresPassport     Boolean     @default(false)
  childPricingType     String?
  childPricingValue    Int?
  childAgeLimit        Int?        @default(12)
  requiredDocuments    Json?
  amenities            String?
  showAmenities        Boolean     @default(false)
  mapLogisticsImageUrl String?
  optionalActivities   String?
  showOptionalActivities Boolean   @default(false)
  Booking              Booking[]
  Country              Country?    @relation(fields: [countryId], references: [id])
  TourAddOn            TourAddOn[]
  TourDay              TourDay[]
}

model TourAddOn {
  id           String         @id
  tourId       String
  name         String
  description  String?
  price        Int            @default(0)
  pricingType  String         @default("PER_BOOKING")
  isRequired   Boolean        @default(false)
  isActive     Boolean        @default(true)
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  BookingAddOn BookingAddOn[]
  Tour         Tour           @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@index([tourId])
}

model TourDay {
  id        String   @id
  tourId    String
  dayIndex  Int
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime
  Tour      Tour     @relation(fields: [tourId], references: [id])
}

model Traveller {
  id                   String                 @id
  userId               String
  firstName            String
  lastName             String
  email                String?
  phone                String?
  dateOfBirth          DateTime?
  passportNumber       String?
  passportExpiry       DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  Document             Document[]
  ApplicationTraveller ApplicationTraveller[]
  BookingTraveller     BookingTraveller[]
  User                 User                   @relation(fields: [userId], references: [id])
}

model User {
  id                                          String          @id @default(cuid())
  name                                        String?
  email                                       String?         @unique
  phone                                       String?         @unique
  phoneVerified                               Boolean         @default(false)
  passwordHash                                String?
  role                                        UserRole        @default(CUSTOMER)
  isActive                                    Boolean         @default(true)
  emailVerified                               Boolean         @default(false)
  emailVerifiedAt                             DateTime?
  passwordResetToken                          String?         @unique
  passwordResetExpires                        DateTime?
  registrationOtp                             String?
  registrationOtpExpires                      DateTime?
  createdAt                                   DateTime        @default(now())
  updatedAt                                   DateTime        @updatedAt
  Application_Application_processedByIdToUser Application[]   @relation("Application_processedByIdToUser")
  Application_Application_userIdToUser        Application[]   @relation("Application_userIdToUser")
  AuditLog                                    AuditLog[]
  Booking_Booking_processedByIdToUser         Booking[]       @relation("Booking_processedByIdToUser")
  Booking_Booking_userIdToUser                Booking[]       @relation("Booking_userIdToUser")
  PasswordReset                               PasswordReset[]
  Payment                                     Payment[]
  Review                                      Review[]
  Traveller                                   Traveller[]
  PromoCodeUsage                              PromoCodeUsage[]
}

model UserNotificationSettings {
  id           String   @id
  userId       String   @unique
  emailEnabled Json     @default("{}")
  inAppEnabled Json     @default("{}")
  pushEnabled  Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime
}

model Visa {
  id                      String                    @id
  countryId               String
  name                    String
  slug                    String                    @unique
  subtitle                String?
  category                String
  isActive                Boolean                   @default(true)
  isFeatured              Boolean                   @default(false)
  priceInInr              Int
  processingTime          String
  stayDuration            String?
  validity                String?
  entryTypeLegacy         String
  overview                String
  eligibility             String
  importantNotes          String?
  rejectionReasons        String?
  whyTravunited           String?
  statistics              String?
  heroImageUrl            String?
  metaTitle               String?
  metaDescription         String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime
  govtFee                 Int?
  serviceFee              Int?
  currency                String?                   @default("INR")
  sampleVisaImageUrl      String?
  visaMode                VisaMode?
  entryType               EntryType?
  stayType                StayType?
  visaSubTypeLabel        String?
  Application             Application[]
  Country                 Country                   @relation(fields: [countryId], references: [id])
  VisaDocumentRequirement VisaDocumentRequirement[]
  VisaFaq                 VisaFaq[]
  VisaSubType             VisaSubType[]
}

model VisaDocumentRequirement {
  id                  String                @id
  visaId              String
  name                String
  description         String?
  scope               DocScope
  isRequired          Boolean               @default(true)
  category            String?
  sortOrder           Int                   @default(0)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  Document            Document[]
  Visa                Visa                  @relation(fields: [visaId], references: [id])
}

model VisaFaq {
  id        String   @id
  visaId    String
  category  String?
  question  String
  answer    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime
  Visa      Visa     @relation(fields: [visaId], references: [id])
}

model VisaSubType {
  id          String        @id
  visaId      String
  label       String
  code        String?
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @default(now())
  Application Application[]
  Visa        Visa          @relation(fields: [visaId], references: [id], onDelete: Cascade)

  @@index([visaId])
}

model VisaType {
  id             String   @id
  country        String
  name           String
  description    String?
  price          Int
  processingTime String?
  stayDuration   String?
  entryType      String?
  requirements   String?
  documents      String?
  eligibility    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
}

model email_events {
  id            String   @id
  type          String
  email         String
  details       Json     @default("{}")
  count         Int      @default(1)
  last_occurred DateTime @default(now())
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now())

  @@unique([email, type])
  @@index([email])
  @@index([type])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  DOC_VERIFY
  DOC_REJECT
  APPROVE
  REJECT
  HIDE
  ANALYTICS_CHANGE
  SETTING_CHANGE
  RESET_PASSWORD
  LOGIN
  LOGOUT
  EXPORT
}

enum AuditEntityType {
  APPLICATION
  BOOKING
  USER
  ADMIN
  SETTINGS
  REVIEW
  PAYMENT
  OTHER
}

enum CareerApplicationStatus {
  NEW
  REVIEWED
  SHORTLISTED
  REJECTED
  ON_HOLD
}

enum CorporateLeadStatus {
  NEW
  CONTACTED
  PROPOSAL_SENT
  WON
  LOST
}

enum CustomTourRequestStatus {
  NEW
  REVIEWED
  QUOTED
  CLOSED
}

enum DocScope {
  PER_TRAVELLER
  PER_APPLICATION
}

enum EntryType {
  SINGLE
  DOUBLE
  MULTIPLE
}

enum ReviewType {
  VISA
  TOUR
}

enum StayType {
  SHORT_STAY
  LONG_STAY
}

enum UserRole {
  CUSTOMER
  STAFF_ADMIN
  SUPER_ADMIN
}

enum VisaMode {
  EVISA
  STICKER
  VOA
  VFS
  ETA
  PRE_ENROLLMENT
  ARRIVAL_CARD
  VISA_FREE_ENTRY
  SCHENGEN_VISA
  APPOINTMENTS
  OTHER
}

enum PromoDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE
}

enum PromoApplicableType {
  VISAS
  TOURS
  BOTH
}

model PromoCode {
  id                String              @id @default(cuid())
  code              String              @unique
  description       String?
  discountType      PromoDiscountType
  discountValue     Int
  minPurchaseAmount Int?
  maxDiscountAmount Int?
  applicableTo      PromoApplicableType @default(BOTH)
  visaIds           String[]
  countryIds        String[]
  tourIds           String[]
  maxUses           Int?
  maxUsesPerUser    Int                 @default(1)
  currentUses       Int                 @default(0)
  restrictedUserIds String[]
  restrictedEmails  String[]
  newUsersOnly      Boolean             @default(false)
  validFrom         DateTime
  validUntil        DateTime
  isActive          Boolean             @default(true)
  createdBy         String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  usages            PromoCodeUsage[]
  Payment           Payment[]
}

model PromoCodeUsage {
  id             String       @id @default(cuid())
  promoCodeId    String
  promoCode      PromoCode    @relation(fields: [promoCodeId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  applicationId  String?
  application    Application? @relation(fields: [applicationId], references: [id])
  bookingId      String?
  booking        Booking?     @relation(fields: [bookingId], references: [id])
  originalAmount Int          @default(0)
  discountAmount Int
  finalAmount    Int
  ipAddress      String?
  usedAt         DateTime     @default(now())
}

model GuestApplication {
  id                String    @id
  guestId           String
  country           String
  visaType          String
  visaId            String?
  selectedSubTypeId String?
  travelDate        DateTime?
  tripType          String?
  nationality       String?
  purposeOfTravel   String?
  stepCompleted     Int       @default(1)
  formData          Json?
  expiresAt         DateTime
  createdAt         DateTime  @default(now())
  updatedAt         DateTime

  @@index([guestId])
}
